# 한국투자증권 Open API 설정
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요
# .env 파일은 절대 git에 커밋하지 마세요!

# 앱 키 (한국투자증권 API 포털에서 발급)
KIS_APP_KEY=your_app_key_here

# 앱 시크릿 (한국투자증권 API 포털에서 발급)
KIS_APP_SECRET=your_app_secret_here

# 조회할 종목 코드 (쉼표로 구분)
# 005930: 삼성전자, 000660: SK하이닉스, 035720: 카카오
KIS_STOCK_CODES=005930,000660,035720

# 모의투자 여부 (true: 모의투자, false: 실전투자)
KIS_IS_MOCK=false

# Google Spreadsheet 설정
# 서비스 계정 JSON 키 (전체 내용을 한 줄로)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# 스프레드시트 ID (URL에서 /d/ 뒤의 값)
# https://docs.google.com/spreadsheets/d/여기가_ID/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Drive 폴더 ID (대장주 분석 결과 업로드용)
# Google Drive 폴더 URL에서 folders/ 뒤의 값
# https://drive.google.com/drive/folders/여기가_ID
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# Gemini API 키 (Google AI Studio에서 발급, 테마 분류용)
GEMINI_API_KEY=your_gemini_api_key_here
